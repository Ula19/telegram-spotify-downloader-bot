# Telegram
BOT_TOKEN=
BOT_USERNAME=your_bot_username

# RapidAPI — один ключ на все движки цепочки
# 1. Регистрация: https://rapidapi.com
# 2. Подписаться (free tier) на движки, которые хочешь держать в цепочке:
#      spotify-downloader9         (основной)
#      spotify-downloader-mp33
#      spotify-downloader23
#      spotify-downloader-v2       (320kbps)
#      spotify-music-mp3-downloader-api
#    Ключ X-RapidAPI-Key у всех один и тот же — вставь его сюда.
# 3. На неподписанные движки придёт 403 — бот их молча пропустит и пойдёт дальше по цепочке.
RAPIDAPI_KEY=

# База данных
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_spotify
DB_USER=postgres
DB_PASSWORD=

# Админы
ADMIN_IDS=
ADMIN_USERNAME=admin

# Кэш
CACHE_TTL_DAYS=1

# Опционально (если RapidAPI заблокирован):
# PROXY_URL=socks5://user:pass@host:port

# Опционально — ключи Spotify API для spotdl-фоллбека (точнее мэтчит трек).
# Без них spotdl тоже работает, но на урезанном SpotipyFree.
# Получить: https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Опционально — cookie-файл YouTube для spotdl. Нужен, если при скачивании
# YouTube требует "Sign in to confirm you're not a bot" (частая история при
# качании через датацентр-прокси). Экспортни куки из браузера в формате Netscape,
# смонтируй файл в контейнер (volume в docker-compose.yml) и укажи путь ВНУТРИ него.
# SPOTDL_COOKIE_FILE=/app/cookies.txt
